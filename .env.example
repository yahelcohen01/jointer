# Public site URL (used for canonical links, OpenGraph). Required in production.
NEXT_PUBLIC_SITE_URL=https://jointer.co

# Supabase project — from Project Settings → API Keys in the Supabase dashboard.
# (Uses the new key model: sb_publishable_* / sb_secret_*. The legacy
#  anon / service_role JWTs are deprecated; do not use them for new projects.)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Secret key — server-only, never expose to the client. Used for admin
# operations that need to bypass RLS (none in Phase 1, but set it now so future
# slices don't need an env-var rotation).
SUPABASE_SECRET_KEY=sb_secret_...
