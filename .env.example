# Public site URL (used for canonical links, OpenGraph). Required in production.
NEXT_PUBLIC_SITE_URL=https://jointer.co

# Supabase project — from Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — server-only, never expose to the client. Used for admin
# operations that need to bypass RLS (none in Phase 1, but set it now so future
# slices don't need an env-var rotation).
SUPABASE_SERVICE_ROLE_KEY=eyJ...
